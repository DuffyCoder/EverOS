# syntax=docker/dockerfile:1.7
#
# Memory Evaluation eval-layer Dockerfile.
#
# Layered on top of an openclaw-base image built from the openclaw repo's
# own Dockerfile with OPENCLAW_EXTENSIONS=memory-core (and any plugin
# being benchmarked) + OPENCLAW_VARIANT=slim.
#
# Run with:
#   harness/build.py --memory-plugin memory-core
# which orchestrates:
#   Step 1: docker build $OPENCLAW_REPO_PATH --build-arg OPENCLAW_EXTENSIONS=...
#           -> tags openclaw-base:<sha>-<plugin>-slim
#   Step 2: docker build openclaw-eval/ --build-arg BASE_IMAGE=...
#           -> tags openclaw-eval:<sha>-<plugin>-slim
#
# Container entrypoint keeps the container alive (sleep) so the harness
# can issue many `docker exec openclaw ...` calls per per-conversation
# container. The per-RPC openclaw invocation is one-shot (CLI, exits).

ARG BASE_IMAGE=openclaw-base:latest
FROM ${BASE_IMAGE}

ARG MEMORY_PLUGIN=memory-core
ARG OPENCLAW_COMMIT=unknown
ARG PLUGIN_REV=unknown
LABEL eval.memory_plugin=${MEMORY_PLUGIN} \
      eval.openclaw_commit=${OPENCLAW_COMMIT} \
      eval.plugin_rev=${PLUGIN_REV} \
      eval.layer=eval-runtime

# We need root briefly to mkdir + install jq + Python (sidecar runtime).
USER root
RUN apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      jq python3 python3-venv python3-pip \
 && rm -rf /var/lib/apt/lists/* \
 && mkdir -p /eval /workspace /etc/openclaw /sidecar \
 && chown -R node:node /eval /workspace /etc/openclaw /sidecar

# Eval-layer assets
COPY --chown=node:node container/openclaw.template.json /etc/openclaw/template.json
COPY --chown=node:node container/entrypoint.sh /eval/entrypoint.sh
COPY --chown=node:node container/openclaw_eval_bridge.mjs /eval/openclaw_eval_bridge.mjs
COPY --chown=node:node container/openclaw_eval_bridge_lib.mjs /eval/openclaw_eval_bridge_lib.mjs
RUN chmod 755 /eval/entrypoint.sh

# Plugin sidecar (FastAPI server + Python deps). build.py stages the
# active plugin's sidecar/ into _active_sidecar/ before invoking docker
# build, or leaves it empty for plugins without a sidecar. The venv
# setup below is a no-op when requirements.txt is absent.
COPY --chown=node:node _active_sidecar/ /sidecar/

USER node
RUN if [ -f /sidecar/requirements.txt ]; then \
      python3 -m venv /sidecar/venv \
      && /sidecar/venv/bin/pip install --no-cache-dir --upgrade pip \
      && /sidecar/venv/bin/pip install --no-cache-dir -r /sidecar/requirements.txt; \
    fi
# Pre-cache the default sentence-transformers model so first /search call
# does not pay the HuggingFace download cost (~80MB). Best-effort: the
# `|| true` lets the build proceed if the cache fetch fails (model will
# download lazily at runtime).
RUN if [ -x /sidecar/venv/bin/python ]; then \
      /sidecar/venv/bin/python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2'); print('precached MiniLM')" || true; \
    fi

USER root
# Memory plugin id is read by entrypoint.sh to render the right plugin
# entries / slot config into /workspace/openclaw.json.
ENV MEMORY_PLUGIN_ID=${MEMORY_PLUGIN}

# Per-conv mounted at /workspace by the harness.
# Use a docker-specific config path so we don't collide with the
# host-side config that the harness writes to /workspace/openclaw.json
# (host paths) for host-side ingest/flush bridge calls.
ENV WORKSPACE_DIR=/workspace
ENV OPENCLAW_CONFIG_PATH=/workspace/openclaw.docker.json
ENV OPENCLAW_STATE_DIR=/workspace/state
ENV HOME=/workspace/home

# Defaults that may be overridden via -e at docker run time.
ENV MEMORY_MODE=memory-core
ENV LLM_BASE_URL=
ENV LLM_API_KEY=
ENV LLM_MODEL=gpt-4.1-mini
ENV SOPH_API_KEY=
ENV SOPH_EMBED_URL=
ENV SOPH_EMBED_EASYLLM_ID=

# Sidecar defaults. MEM0_PORT must match what the plugin's sidecarUrl
# points at (default http://localhost:8765 in plugin code).
ENV MEM0_PORT=8765
ENV MEM0_INFER=false
ENV MEM0_DATA_DIR=/workspace/state/mem0

# EverMemOS plugin defaults (memory_mode=evermemos). Plugin reads
# EVERMEMOS_API_URL/KEY at registration; OpenClawDockerAdapter forwards
# them via -e when memory_mode=evermemos. host.docker.internal resolves
# to the host machine when the container is started with
# --add-host=host.docker.internal:host-gateway (also handled by
# OpenClawDockerAdapter for this memory_mode).
ENV EVERMEMOS_API_URL=http://host.docker.internal:1995
ENV EVERMEMOS_API_KEY=

# Drop back to non-root for runtime.
USER node

# Override openclaw's default gateway CMD - we want a passive long-lived
# container that the harness drives via docker exec.
ENTRYPOINT ["/eval/entrypoint.sh"]
CMD ["sleep", "infinity"]
